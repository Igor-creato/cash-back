<?xml version="1.0"?>
<ruleset name="Cashback Plugin — Safe Autofix">
    <description>
        Подмножество правил для БЕЗОПАСНОГО автоисправления через phpcbf.
        Включает только форматирование/пробелы/отступы/запятые.
        НЕ трогает логику, безопасность, escaping, SQL, nonce и т.п.
    </description>

    <file>.</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/wp-plugin-tests/*</exclude-pattern>
    <exclude-pattern>*/obsidian/*</exclude-pattern>
    <exclude-pattern>*/context/*</exclude-pattern>
    <exclude-pattern>*/development/*</exclude-pattern>
    <exclude-pattern>*/languages/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>
    <arg name="parallel" value="8"/>
    <arg name="tab-width" value="4"/>

    <!-- Пробелы / табы / EOL -->
    <rule ref="Generic.WhiteSpace.DisallowTabIndent"/>
    <rule ref="Generic.WhiteSpace.ScopeIndent"/>
    <rule ref="Generic.WhiteSpace.IncrementDecrementSpacing"/>
    <rule ref="Generic.WhiteSpace.LanguageConstructSpacing"/>
    <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace"/>
    <rule ref="Squiz.WhiteSpace.CastSpacing"/>
    <rule ref="Squiz.WhiteSpace.LogicalOperatorSpacing"/>
    <rule ref="Squiz.WhiteSpace.SemicolonSpacing"/>
    <rule ref="Squiz.WhiteSpace.OperatorSpacing"/>
    <rule ref="PSR2.Files.EndFileNewline"/>
    <rule ref="Generic.Files.LineEndings">
        <properties>
            <property name="eolChar" value="\n"/>
        </properties>
    </rule>

    <!-- Массивы: запятые, отступы, пробелы внутри -->
    <rule ref="WordPress.Arrays.ArrayIndentation"/>
    <rule ref="WordPress.Arrays.ArrayKeySpacingRestrictions"/>
    <rule ref="WordPress.Arrays.ArrayDeclarationSpacing"/>
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>

    <!-- Строки: пробелы вокруг конкатенации -->
    <rule ref="Squiz.Strings.ConcatenationSpacing">
        <properties>
            <property name="spacing" value="1"/>
            <property name="ignoreNewlines" value="true"/>
        </properties>
    </rule>

    <!-- Control structures: пробелы, фигурные скобки -->
    <rule ref="WordPress.WhiteSpace.ControlStructureSpacing"/>
    <rule ref="Generic.ControlStructures.InlineControlStructure"/>
    <rule ref="Squiz.ControlStructures.ControlSignature"/>
    <rule ref="PEAR.ControlStructures.MultiLineCondition"/>

    <!-- PHP-теги / short open -->
    <rule ref="Generic.PHP.DisallowShortOpenTag"/>
    <rule ref="Generic.PHP.LowerCaseKeyword"/>
    <rule ref="Generic.PHP.LowerCaseType"/>
    <rule ref="Generic.PHP.LowerCaseConstant"/>

    <!-- Формат объявления функций -->
    <rule ref="Squiz.Functions.FunctionDeclarationArgumentSpacing"/>
    <rule ref="Generic.Functions.FunctionCallArgumentSpacing"/>

    <!-- Запрет лишних пустых строк -->
    <rule ref="Squiz.WhiteSpace.FunctionSpacing">
        <properties>
            <property name="spacing" value="1"/>
            <property name="spacingBeforeFirst" value="0"/>
            <property name="spacingAfterLast" value="0"/>
        </properties>
    </rule>
</ruleset>
