<?xml version="1.0"?>
<ruleset name="Cashback Plugin">
    <description>Coding &amp; security standards for Cashback Plugin (WordPress/WooCommerce).</description>

    <file>.</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/wp-plugin-tests/*</exclude-pattern>
    <exclude-pattern>*/obsidian/*</exclude-pattern>
    <exclude-pattern>*/context/*</exclude-pattern>
    <exclude-pattern>*/development/*</exclude-pattern>
    <exclude-pattern>*/languages/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>
    <arg name="parallel" value="8"/>

    <!-- WordPress core + extras (security/db/xss/nonce sniffs live here). -->
    <rule ref="WordPress">
        <exclude name="Generic.Commenting.DocComment.MissingShort"/>
        <exclude name="Squiz.Commenting"/>
        <exclude name="WordPress.Files.FileName"/>
        <exclude name="Generic.WhiteSpace.DisallowSpaceIndent"/>
        <exclude name="WordPress.WhiteSpace"/>
        <exclude name="Generic.WhiteSpace.ScopeIndent"/>
        <exclude name="PEAR.Functions.FunctionCallSignature"/>
    </rule>

    <rule ref="WordPress-Extra">
        <exclude name="Generic.Commenting.DocComment"/>
        <exclude name="Squiz.Commenting"/>
    </rule>

    <!-- VIP minimum: security-focused sniffs (from automattic/vipwpcs). -->
    <rule ref="WordPress-VIP-Go">
        <exclude name="WordPressVIPMinimum.Files.IncludingFile"/>
        <exclude name="WordPressVIPMinimum.Functions.RestrictedFunctions"/>
        <!-- Self-hosted plugin (not VIP platform): plugin JOINs custom tables with wp_users as a domain requirement; no object-cache layer applies. -->
        <exclude name="WordPressVIPMinimum.Variables.RestrictedVariables.user_meta__wpdb__users"/>
        <!-- UA and cookies are request-scoped inputs (bot detection, referral HMAC cookie); caching across requests is semantically wrong. -->
        <exclude name="WordPressVIPMinimum.Variables.RestrictedVariables.cache_constraints___SERVER__HTTP_USER_AGENT__"/>
        <exclude name="WordPressVIPMinimum.Variables.RestrictedVariables.cache_constraints___COOKIE"/>
    </rule>

    <!-- meta_query used only in admin-only CPA network activate/deactivate toggle (cold path). -->
    <rule ref="WordPress.DB.SlowDBQuery.slow_db_query_meta_query">
        <severity>0</severity>
    </rule>

    <!-- Legitimate direct queries against custom plugin tables (cashback_*, affiliate_*, claims_*, support_*). Core WP has no API for these. -->
    <rule ref="WordPress.DB.DirectDatabaseQuery.DirectQuery">
        <severity>0</severity>
    </rule>
    <!-- Plugin handles transactional state (balances, payouts, idempotency, FOR UPDATE locks). Caching reads would break consistency — caching is intentionally avoided. -->
    <rule ref="WordPress.DB.DirectDatabaseQuery.NoCaching">
        <severity>0</severity>
    </rule>
    <!-- Schema migrations (dbDelta / ALTER) in mariadb.php and *-db.php files — by design. -->
    <rule ref="WordPress.DB.DirectDatabaseQuery.SchemaChange">
        <severity>0</severity>
    </rule>

    <!-- Codebase convention: natural conditions, not Yoda. -->
    <rule ref="WordPress.PHP.YodaConditions.NotYoda">
        <severity>0</severity>
    </rule>
    <!-- Short ternary ($x ?: $y) is used intentionally throughout the codebase. -->
    <rule ref="Universal.Operators.DisallowShortTernary.Found">
        <severity>0</severity>
    </rule>

    <!-- Force critical security sniffs to be errors, not warnings. -->
    <rule ref="WordPress.DB.PreparedSQL">
        <type>error</type>
    </rule>
    <rule ref="WordPress.DB.PreparedSQLPlaceholders">
        <type>error</type>
    </rule>
    <rule ref="WordPress.DB.DirectDatabaseQuery">
        <type>error</type>
    </rule>
    <rule ref="WordPress.Security.EscapeOutput">
        <type>error</type>
    </rule>
    <rule ref="WordPress.Security.NonceVerification">
        <type>error</type>
    </rule>
    <rule ref="WordPress.Security.ValidatedSanitizedInput">
        <type>error</type>
    </rule>

    <!-- PHP 8.1..8.4 compatibility. -->
    <rule ref="PHPCompatibilityWP"/>

    <config name="minimum_supported_wp_version" value="6.5"/>
    <config name="testVersion" value="8.1-"/>
</ruleset>
